<layout>

    <data>

        <variable
            name="medicineModel"
            type="com.kotlin.dvijaypatient.model.MedicineModel" />

    </data>


    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">



        <androidx.cardview.widget.CardView

            android:id="@+id/card_medicine"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginBottom="10dp"

            android:backgroundTint="#F5F5F5"

            android:elevation="3dp"

            app:cardCornerRadius="12dp">



            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:orientation="vertical"

                android:padding="10dp"

                android:layout_marginStart="10dp">





                <!-- Medicine Name -->

                <LinearLayout

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:orientation="horizontal">



                    <ImageView

                        android:layout_width="22dp"

                        android:layout_height="32dp"

                        android:src="@drawable/pill"/>



                    <TextView

                        android:id="@+id/tvMedicineName"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:layout_marginStart="10dp"

                        android:text="Paracetamol 500mg"

                        android:textColor="#000000"

                        android:textSize="15sp"

                        android:textStyle="bold"/>


                </LinearLayout>






                <!-- Time -->

                <LinearLayout

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="8dp"

                    android:orientation="horizontal">



                    <ImageView

                        android:layout_width="20dp"

                        android:layout_height="20dp"

                        android:src="@drawable/clock"

                        app:tint="#757575"/>



                    <TextView

                        android:id="@+id/tvTime"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:layout_marginStart="10dp"

                        android:text="8:00 AM | After Food | 1 Tab"

                        android:textColor="#757575"

                        android:textSize="13sp"/>


                </LinearLayout>






                <!-- From Date To Date -->

                <LinearLayout

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="8dp"

                    android:orientation="horizontal">



                    <ImageView

                        android:layout_width="20dp"

                        android:layout_height="20dp"

                        android:src="@drawable/calendar"

                        app:tint="#757575"/>




                    <TextView

                        android:id="@+id/tvDateRange"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:layout_marginStart="10dp"

                        android:text="29-06-2026 To 05-07-2026"

                        android:textColor="#757575"

                        android:textSize="13sp"/>


                </LinearLayout>





            </LinearLayout>



        </androidx.cardview.widget.CardView>



    </LinearLayout>


</layout>