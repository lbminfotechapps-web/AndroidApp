<?xml version="1.0" encoding="utf-8"?>
<layout>
    <data>
        <variable
            name="reminderViewModel"
            type="com.kotlin.dvijaypatient.ui.fragment.reminder.ReminderViewModel" />
    </data>

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
       >


        <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F5F7FB"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tvReportTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:layout_gravity="center"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_20sdp"
                    android:layout_marginLeft="@dimen/_10sp"
                    android:text="Medicine Wise Schedule"/>

                <!-- Pill Name Card -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPillName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#DDE6F4"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvProductName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvPillName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pill's Name"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etMedicineName"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:hint="Medication Name"
                            android:paddingHorizontal="14dp"
                            android:textColor="#222222"
                            android:textColorHint="#8A8A8A" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Medicine Type -->


                <!-- Start End Date -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDate"
                    android:layout_width="match_parent"
                    android:layout_height="112dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/llStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="18dp">

                            <TextView
                                android:id="@+id/tvStartDateTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Start Date"
                                android:textColor="#111111"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvStartDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jun 15"
                                android:textColor="#3B6EFF"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_arrow_down" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llEndtDate"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="18dp">

                            <TextView
                                android:id="@+id/tvEndDateTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="End Date"
                                android:textColor="#111111"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvEndDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jun 25"
                                android:textColor="#3B6EFF"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_arrow_down" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Pills + Dose -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pills"
                                android:textColor="#111111"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/tvPillsCnt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01"
                                android:inputType="number"
                                android:paddingVertical="5dp"
                                android:paddingHorizontal="10dp"
                                android:background="@null"
                                android:textColor="#888888"
                                android:textSize="18sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:id="@+id/llDose"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:id="@+id/tvDose"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tablet"
                                android:textColor="#3B6EFF"
                                android:textSize="14sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/ivDoseArrow"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_arrow_down" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>                </LinearLayout>

                <!-- Frequency -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:id="@+id/llFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Set Frequency"
                            android:textColor="#111111"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFrequency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 time,Daily"
                            android:textColor="#3B6EFF"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="0.1" />

                        <ImageView
                            android:id="@+id/ivFreqArrow"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_down" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Schedule Time -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_gravity="center_vertical"
                    android:text="Schedule Time"
                    android:layout_marginStart="4dp"
                    android:textColor="#111111"
                    android:textStyle="bold" />


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardScheduleTime"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="5dp"

                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="18dp">
                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:layout_marginTop="3dp"
                            android:gravity="center_vertical"
                            android:layout_gravity="center_vertical"
                            android:textColor="#3B6EFF" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical|end"
                        android:layout_marginTop="2dp"
                        >



                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="@dimen/_5sp"
                            android:src="@drawable/ic_arrow_down" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Done Button -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDone"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="20dp"
                    app:backgroundTint="#1E88E5"
                    android:background="@drawable/bg_gradient_button"
                    android:text="Done"

                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </ScrollView>
    </LinearLayout>
</layout>