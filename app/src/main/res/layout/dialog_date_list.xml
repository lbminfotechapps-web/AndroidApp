<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"

    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >
     <RelativeLayout
         android:layout_width="match_parent"
         android:layout_height="wrap_content">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medicine Compliance Pending"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@color/color_blue"
            android:textStyle="bold"
            android:padding="@dimen/_3sp"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:paddingBottom="8dp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="28dp"
            android:text="Choose a date to mark medicine status"
            android:textSize="13sp"
            android:background="@color/color_blue"
            android:textColor="@color/white"
            android:paddingBottom="4dp"/>

         <ImageView
             android:id="@+id/imgClose"
             android:layout_width="30dp"
             android:layout_height="30dp"
             android:layout_marginTop="@dimen/_10sp"
             android:layout_marginRight="@dimen/_10sp"
             android:layout_alignParentEnd="true"
             android:src="@drawable/close_icon"/>

     </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="@dimen/_16sp"
            android:layout_marginRight="@dimen/_16sp"
            android:background="#E0E0E0"/>

        <!-- 🔷 Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDates"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingTop="10dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>