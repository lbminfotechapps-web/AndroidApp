<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_blue"
        android:orientation="vertical">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardElevation="8dp"
            app:shapeAppearanceOverlay="@style/TopRoundedCard">



            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <!-- MAIN CONTAINER -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal"
                        android:elevation="4dp"
                        >

                        <!-- PROFILE -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/imgProfile"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:src="@drawable/profile_new"
                                android:background="@drawable/round_profile"
                                android:padding="10dp" />

                            <!-- Hide edit icon if not needed -->
                            <ImageView
                                android:id="@+id/imgEdit"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="end|bottom"
                                android:background="@drawable/profile_bg"
                                android:padding="4dp"
                                android:src="@drawable/edit"
                                android:visibility="gone"/>
                        </FrameLayout>

                        <!-- TITLE -->
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Patient Name"
                            android:textSize="18sp"
                            android:visibility="gone"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"/>

                        <!-- USERNAME -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Username"
                            android:visibility="gone"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="20dp"/>

                        <TextView
                            android:id="@+id/tvName"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:visibility="gone"
                            android:gravity="center_vertical"/>

                        <!-- EMAIL -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- PASSWORD -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Password"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvPassword"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:visibility="gone"
                            android:gravity="center_vertical"/>

                        <!-- GENDER -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gender"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvGender"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- DOB -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Date of Birth"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvDob"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- MOBILE 1 -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mobile No 1"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvMobile1"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- MOBILE 2 -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mobile No 2"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvMobile2"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- PARENT MOBILE -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Parent Mobile"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvParentMobile"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- ADDRESS -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Address"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="top"/>

                        <!-- CITY -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="City"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvCity"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- DISTRICT -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="District"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvDistrict"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- STATE -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="State"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvState"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- DOCTOR -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ref Doctor"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvDoctor"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                        <!-- BRANCH -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Branch"
                            android:textSize="12sp"
                            android:textColor="#6B7A8C"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvBranch"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_field"
                            android:padding="12dp"
                            android:gravity="center_vertical"/>

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</layout>