<?xml version="1.0" encoding="utf-8"?>
<layout>
    <data>
        <variable
            name="setReminderViewModel"
            type="com.kotlin.dvijaypatient.ui.fragment.set_reminder.SetReminderViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F2F2">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Days of the Week"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivOk"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/check_large" />
        </LinearLayout>

        <!-- Clear Button -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:text="Clear"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Days List -->
        <LinearLayout
            android:id="@+id/containerDays"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnClear"
            app:layout_constraintBottom_toTopOf="@id/tvFooter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Sunday -->
            <LinearLayout
                android:id="@+id/daySunday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvSunday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sunday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgSunday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Monday -->
            <LinearLayout
                android:id="@+id/dayMonday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvMonday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Monday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgMonday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Tuesday -->
            <LinearLayout
                android:id="@+id/dayTuesday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvTuesday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tuesday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgTuesday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Wednesday -->
            <LinearLayout
                android:id="@+id/dayWednesday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvWednesday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Wednesday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgWednesday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Thursday -->
            <LinearLayout
                android:id="@+id/dayThursday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvThursday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thursday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgThursday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Friday -->
            <LinearLayout
                android:id="@+id/dayFriday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvFriday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Friday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgFriday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Saturday -->
            <LinearLayout
                android:id="@+id/daySaturday"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvSaturday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Saturday"
                    android:textSize="16sp"
                    android:textColor="@android:color/black" />

                <ImageView
                    android:id="@+id/imgSaturday"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_large"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Select all the days of the week to take this drug."
            android:textColor="#555"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>